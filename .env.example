# .env.example — Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────

# ── Government API (data.gov.in) ──────────────────────────────
# 1. Register at: https://data.gov.in/user/register
# 2. Get API key: https://data.gov.in/user/me/api-keys
DATA_GOV_API_KEY=your_data_gov_in_api_key_here

# ── Supabase ──────────────────────────────────────────────────
# From Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Frontend (Vite) ───────────────────────────────────────────
# Supabase anon key (safe to expose in frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_BACKEND_URL=http://localhost:8000

# ── Backend ───────────────────────────────────────────────────
FRONTEND_URL=https://your-production-frontend.com

# ── Supabase Edge Functions ───────────────────────────────────
# Set these in Supabase Dashboard → Edge Functions → Secrets
ANTHROPIC_API_KEY=your_anthropic_api_key_here
BACKEND_URL=https://your-backend-domain.com
